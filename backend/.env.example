# Application
DEBUG=true
PORT=8080

# Database (choose one)
# MySQL
DSN=root:root@tcp(127.0.0.1:3306)/ai_optimizer?charset=utf8mb4&parseTime=True&loc=Local
DATABASE=mysql

# PostgreSQL
# DSN=host=localhost user=postgres password=postgres dbname=ai_optimizer port=5432 sslmode=disable
# DATABASE=postgres

# Encryption (32 bytes, required for production)
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# Sync
SYNC_INTERVAL=60

# GitLab
GITLAB_SECRET=your-gitlab-webhook-secret

# Task
TASK_TIMEOUT_MIN=30
MAX_PARALLEL_TASK=20
BRANCH_PREFIX=AI-
RAND_LENGTH=4
